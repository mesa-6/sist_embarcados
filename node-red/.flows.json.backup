    {
        "id": "50acea4213361356",
        "type": "function",
        "z": "ce1e45cbf51fc423",
        "name": "function 2",
        "func": "// ========================================\n// 1. SUA LÓGICA DE DADOS (Mantida)\n// ========================================\nlet nivelAtual = context.get('nivelAtual') || 82;\nnivelAtual += (Math.random() * 2) - 2.5;\n\nif (nivelAtual > 100) nivelAtual = 100;\nif (nivelAtual < 0) nivelAtual = 0;\ncontext.set('nivelAtual', nivelAtual);\n\n// Payload com o número puro para o gráfico acumular o histórico\nmsg.payload = parseFloat(nivelAtual.toFixed(1));\nmsg.topic = \"Nível da Água (%)\";\n\n// ========================================\n// 2. CONFIGURAÇÃO DIRETA DO ECHARTS (msg.ui_update)\n// ========================================\nmsg.ui_update = {\n    chartOptions: {\n        color: ['#3da8ff'],\n        \n        // 🛠️ SOLUÇÃO: Cria um espaçamento na base do gráfico para a legenda não cobrir o eixo X\n        grid: {\n            top: 20,       // Margem superior interna\n            left: 40,      // Margem esquerda para os números do eixo Y\n            right: 20,     // Margem direita\n            bottom: 60     // Espaço generoso na base para o eixo X + Legenda respirarem\n        },\n\n        series: [{\n            name: \"Nível da Água (%)\",\n            type: 'line',\n            smooth: true,\n            symbol: 'circle',\n            symbolSize: 10,\n            areaStyle: {\n                color: {\n                    type: 'linear',\n                    x: 0, y: 0, x2: 0, y2: 1,\n                    colorStops: [\n                        { offset: 0, color: 'rgba(61, 168, 255, 0.25)' },\n                        { offset: 1, color: 'rgba(61, 168, 255, 0.01)' }\n                    ]\n                }\n            },\n            lineStyle: {\n                width: 3\n            }\n        }],\n        \n        legend: {\n            show: true,\n            bottom: 5,                  // Fixa bem na bordinha de baixo do footer\n            selectedMode: false,\n            textStyle: {\n                color: '#A9B4C2',\n                fontFamily: 'sans-serif'\n            }\n        },\n        \n        xAxis: {\n            axisLine: { show: false },\n            splitLine: { show: false },\n            axisLabel: {\n                color: '#A9B4C2',\n                margin: 12              // Afasta o texto das horas um pouco da linha do eixo\n            }\n        },\n        yAxis: {\n            min: 0,\n            max: 100,\n            splitLine: {\n                lineStyle: {\n                    color: 'rgba(255, 255, 255, 0.05)'\n                }\n            },\n            axisLabel: {\n                color: '#A9B4C2'\n            }\n        }\n    }\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
