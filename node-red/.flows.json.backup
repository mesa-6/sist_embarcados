    {
        "id": "3a7cd451a75a9686",
        "type": "function",
        "z": "ce1e45cbf51fc423",
        "name": "function 4",
        "func": "// ========================================\n// 1. LÓGICA DE DADOS (Número Puro para o Histórico)\n// ========================================\nlet turbidezAtual = context.get('turbidezAtual') || 50;\nturbidezAtual += (Math.random() * 4) - 1.8;\n\nif (turbidezAtual > 100) turbidezAtual = 100;\nif (turbidezAtual < 0) turbidezAtual = 0;\ncontext.set('turbidezAtual', turbidezAtual);\n\n// Payload puro para o gráfico acumular o histórico\nmsg.payload = parseFloat(turbidezAtual.toFixed(1));\nmsg.topic = \"Turbidez (NTU)\";\n\n// ========================================\n// 2. CONFIGURAÇÃO DIRETA DO ECHARTS (msg.ui_update)\n// ========================================\nmsg.ui_update = {\n    chartOptions: {\n         grid: {\n            top: 20,       // Margem superior interna\n            left: 40,      // Margem esquerda para os números do eixo Y\n            right: 20,     // Margem direita\n            bottom: 60     // Espaço generoso na base para o eixo X + Legenda respirarem\n        },\n        // Define a cor principal da linha (Laranja)\n        color: ['#FF7A00'],\n        \n        // Configuração da Linha e da Sombra (Series no eCharts)\n        series: [{\n            name: \"Turbidez (NTU)\",\n            type: 'line',\n            smooth: true,               // CURVA SUAVE (Igual ao tension do Chart.js)\n            symbol: 'circle',           // Força as bolinhas aparecerem\n            symbolSize: 10,             // Tamanho das bolinhas fixas na linha\n            \n            // Ativa e estiliza a sombra/área preenchida abaixo da linha\n            areaStyle: {\n                color: {\n                    type: 'linear',\n                    x: 0, y: 0, x2: 0, y2: 1,\n                    colorStops: [\n                        { offset: 0, color: 'rgba(255, 122, 0, 0.25)' }, // Laranja mais visível no topo\n                        { offset: 1, color: 'rgba(255, 122, 0, 0.01)' }  // Some suavemente perto do zero\n                    ]\n                }\n            },\n            lineStyle: {\n                width: 3                // Espessura robusta da linha principal\n            }\n        }],\n        \n        // LEGENDA NO FOOTER E TRAVADA\n        legend: {\n            show: true,\n            bottom: 5,                  // Coloca a legenda lá no rodapé (Footer)\n            selectedMode: false,        // DESATIVA O CLIQUE (Clicar não faz a linha sumir!)\n            textStyle: {\n                color: '#A9B4C2',\n                fontFamily: 'sans-serif'\n            }\n        },\n        \n        // AJUSTE DOS EIXOS (Igual às imagens de referência)\n        xAxis: {\n            \n            axisLine: { show: false },  // Limpa a linha do eixo X\n            splitLine: { show: false },  // Remove grades verticais\n            axisLabel: {\n                color: '#A9B4C2',\n                margin: 12              // Afasta o texto das horas um pouco da linha do eixo\n            }\n        },\n        yAxis: {\n            min: 0,\n            max: 100,\n            splitLine: {\n                lineStyle: {\n                    color: 'rgba(255, 255, 255, 0.05)' // Linhas horizontais bem discretas\n                }\n            },\n            axisLabel: {\n                color: '#A9B4C2',\n                margin: 12  \n            }\n        }\n    }\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 680,
        "wires": [
            [
                "e4f7e5879ac68341"
            ]
        ]
    },
    {
        "id": "7849f3f379aa2899",
        "type": "ui-template",
        "z": "ce1e45cbf51fc423",
        "group": "f3c1e039f7c79075",
        "page": "",
        "ui": "",
        "name": "Status do sistema",
        "order": 0,
        "width": "0",
        "height": "0",
        "head": "",
        "format": "<template>\n    <div class=\"card\">\n        <div class=\"title\">\n            STATUS GERAL DO SISTEMA\n        </div>\n\n        <div class=\"gauge-container status-block-adjust\">\n            <div class=\"status-rows-inner\">\n                <div class=\"status-item-row\">\n                    <div class=\"item-left\">\n                        <span :class=\"['status-led', system.mqtt === 'ONLINE' ? 'led-green' : 'led-red']\"></span>\n                        <span class=\"mdi mdi-cloud-outline item-icon\"></span>\n                        <span class=\"item-label\">MQTT Broker</span>\n                    </div>\n                    <span :class=\"['item-value', system.mqtt === 'ONLINE' ? 'text-green' : 'text-red']\">\n                        {{ system.mqtt }}\n                    </span>\n                </div>\n\n                <div class=\"status-item-row\">\n                    <div class=\"item-left\">\n                        <span :class=\"['status-led', system.sensores === 'OK' ? 'led-green' : (system.sensores === 'OSCILANDO' ? 'led-orange' : 'led-red')]\"></span>\n                        <span class=\"mdi mdi-transmission-tower item-icon\"></span>\n                        <span class=\"item-label\">Sensores</span>\n                    </div>\n                    <span :class=\"['item-value', system.sensores === 'OK' ? 'text-green' : (system.sensores === 'OSCILANDO' ? 'text-orange' : 'text-red')]\">\n                        {{ system.sensores }}\n                    </span>\n                </div>\n\n                <div class=\"status-item-row\">\n                    <div class=\"item-left\">\n                        <span :class=\"['status-led', system.db === 'CONECTADO' ? 'led-green' : (system.db === 'LENTO' ? 'led-orange' : 'led-red')]\"></span>\n                        <span class=\"mdi mdi-database item-icon\"></span>\n                        <span class=\"item-label\">Banco de Dados</span>\n                    </div>\n                    <span :class=\"['item-value', system.db === 'CONECTADO' ? 'text-green' : (system.db === 'LENTO' ? 'text-orange' : 'text-red')]\">\n                        {{ system.db }}\n                    </span>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"status\">\n            Última Leitura:\n            <span class=\"text-blue\">\n                {{ system.lastSeen }}\n            </span>\n        </div>\n\n        <div class=\"insight\">\n            Próxima atualização estimada em:\n            <span class=\"text-white-bold\">{{ nextReading }}</span>\n        </div>\n    </div>\n</template>\n\n<script>\n    export default {\n    data() {\n        return {\n            system: {\n                mqtt: \"ONLINE\",\n                sensores: \"OK\",\n                db: \"CONECTADO\",\n                lastSeen: \"10:25:59\"\n            },\n            countdown: 60, // Segundos para a próxima atualização\n            timer: null\n        }\n    },\n    computed: {\n        nextReading() {\n            return `${this.countdown}s`;\n        }\n    },\n    methods: {\n        startCountdown() {\n            if (this.timer) clearInterval(this.timer);\n            this.countdown = 60; // Reseta para 60 segundos\n            this.timer = setInterval(() => {\n                if (this.countdown > 0) {\n                    this.countdown--;\n                }\n            }, 1000);\n        }\n    },\n    watch: {\n        msg: {\n            handler(newMsg) {\n                if (newMsg && newMsg.payload !== undefined && newMsg.payload !== null) {\n                    if (typeof newMsg.payload === 'object') {\n                        this.system = { ...this.system, ...newMsg.payload };\n                    } else {\n                        const agora = new Date();\n                        this.system.lastSeen = agora.toTimeString().split(' ')[0];\n                    }\n                    this.startCountdown(); // Reinicia o contador ao receber dados\n                }\n            },\n            immediate: true,\n            deep: true\n        }\n    },\n    mounted() {\n        this.startCountdown();\n    },\n    beforeDestroy() {\n        if (this.timer) clearInterval(this.timer);\n    }\n}\n</script>\n\n<style>\n    /* COMPARTILHAMENTO DE REGRAS DE CAIXA IDÊNTICAS */\n    .card {\n        background: #0B1728;\n        border-radius: 18px;\n        padding: 16px;\n        color: #F5F7FA;\n        box-shadow: 0 0 20px rgba(0, 0, 0, 0.3);\n        width: 100%;\n        height: 100%;\n        box-sizing: border-box;\n        display: flex;\n        flex-direction: column;\n        justify-content: space-between;\n    }\n\n    .title {\n        font-size: clamp(16px, 1.8vw, 22px);\n        font-weight: bold;\n        color: #3BA4FF;\n        text-align: center;\n        margin-bottom: 8px;\n    }\n\n    /* PREENCHE EXATAMENTE OS 230PX DA TURBIDEZ */\n    .gauge-container.status-block-adjust {\n        position: relative;\n        width: 100%;\n        height: 230px;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        box-sizing: border-box;\n    }\n\n    /* ESPAÇAMENTO EQUILIBRADO PARA AS 3 LINHAS DENTRO DO BLOCO DE 230PX */\n    .status-rows-inner {\n        display: flex;\n        flex-direction: column;\n        justify-content: center;\n        gap: 26px;\n        width: 100%;\n        padding: 0 4px;\n        box-sizing: border-box;\n    }\n\n    .status-item-row {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        padding-bottom: 8px;\n        border-bottom: 1px solid rgba(255, 255, 255, 0.04);\n    }\n\n    .status-item-row:last-child {\n        border-bottom: none;\n    }\n\n    .item-left {\n        display: flex;\n        align-items: center;\n    }\n\n    /* LEDS INDICADORES */\n    .status-led {\n        width: 8px;\n        height: 8px;\n        border-radius: 50%;\n        margin-right: 12px;\n        display: inline-block;\n    }\n\n    .led-green {\n        background-color: #22C55E;\n        box-shadow: 0 0 8px #22C55E;\n    }\n\n    .led-orange {\n        background-color: #F59E0B;\n        box-shadow: 0 0 8px #F59E0B;\n    }\n\n    .led-red {\n        background-color: #EF4444;\n        box-shadow: 0 0 8px #EF4444;\n    }\n\n    /* ÍCONES */\n    .item-icon {\n        font-size: 18px;\n        color: #A9B4C2;\n        margin-right: 10px;\n        display: flex;\n        align-items: center;\n    }\n\n    /* TEXTOS */\n    .item-label {\n        font-size: 14px;\n        color: #E2E8F0;\n        font-weight: 500;\n    }\n\n    .item-value {\n        font-size: 14px;\n        font-weight: bold;\n    }\n\n    /* CORES DE STATUS */\n    .text-green {\n        color: #22C55E;\n    }\n\n    .text-orange {\n        color: #F59E0B;\n    }\n\n    .text-red {\n        color: #EF4444;\n    }\n\n    .text-blue {\n        color: #38BDF8;\n    }\n\n    .text-white-bold {\n        color: #FFFFFF;\n        font-weight: bold;\n        margin-left: 4px;\n    }\n\n    /* RODAPÉS REPLICADOS DO CARD DE TURBIDEZ */\n    .status {\n        margin-top: 6px;\n        font-size: clamp(14px, 1.5vw, 18px);\n        text-align: center;\n        font-weight: bold;\n    }\n\n    .insight {\n        margin-top: 10px;\n        text-align: center;\n        font-size: clamp(11px, 1.2vw, 15px);\n        color: #A9B4C2;\n        line-height: 1.4;\n    }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1150,
        "y": 600,
        "wires": [
            []
        ]
    },
    {
        "id": "88f87c611a264f7c",
        "type": "function",
        "z": "ce1e45cbf51fc423",
        "name": "function 5",
        "func": "// 1. Array de estados possíveis para cada componente para criar variedade na simulação\nconst estadosMQTT = [\"ONLINE\", \"ONLINE\", \"ONLINE\", \"OFFLINE\"];\nconst estadosSensores = [\"OK\", \"OK\", \"OSCILANDO\", \"ERRO\"];\nconst estadosDB = [\"CONECTADO\", \"CONECTADO\", \"LENTO\", \"DESCONECTADO\"];\n\n// 2. Sorteia um estado aleatório para cada um deles\nlet mqttSorteado = estadosMQTT[Math.floor(Math.random() * estadosMQTT.length)];\nlet sensoresSorteados = estadosSensores[Math.floor(Math.random() * estadosSensores.length)];\nlet dbSorteado = estadosDB[Math.floor(Math.random() * estadosDB.length)];\n\n// 3. Captura o horário exato em tempo real (Formato HH:MM:SS)\nlet agora = new Date();\nlet horaFormatada = agora.toTimeString().split(' ')[0];\n\n// 4. Monta o objeto JSON enviando também o tempo do próximo intervalo (10 segundos)\nmsg.payload = {\n    mqtt: mqttSorteado,\n    sensores: sensoresSorteados,\n    db: dbSorteado,\n    lastSeen: horaFormatada,\n    intervalo: 10 // Define dinamicamente o tempo de 10s para o card Vue\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 920,
        "y": 600,
        "wires": [
            [
                "7849f3f379aa2899"
            ]
        ]
    },
