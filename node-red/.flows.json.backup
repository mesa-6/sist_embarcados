    {
        "id": "eec55726d41a2347",
        "type": "ui-template",
        "z": "ce1e45cbf51fc423",
        "group": "be7d576764ebb1fa",
        "page": "",
        "ui": "",
        "name": "Turbidez",
        "order": 1,
        "width": "0",
        "height": "0",
        "head": "",
        "format": "<template>\n    <div class=\"card\">\n\n        <div class=\"title\">\n            TURBIDEZ DA ÁGUA\n        </div>\n\n        <div class=\"gauge-container\">\n\n            <svg class=\"gauge\" viewBox=\"0 0 200 140\">\n\n                <path d=\"M20 100 A80 80 0 0 1 180 100\" class=\"gauge-bg\" />\n\n                <path d=\"M20 100 A80 80 0 0 1 180 100\" class=\"gauge-fill\" :style=\"gaugeStyle\" />\n\n            </svg>\n\n            <div class=\"value-container\">\n\n                <div class=\"value\">\n                    {{ turbidez }}\n                </div>\n\n                <div class=\"unit\">\n                    NTU\n                </div>\n\n            </div>\n\n        </div>\n\n        <div class=\"status\">\n\n            Qualidade:\n\n            <span :style=\"{ color: statusColor }\">\n                {{ statusText }}\n            </span>\n\n        </div>\n\n        <div class=\"insight\">\n            {{ insightText }}\n        </div>\n\n    </div>\n</template>\n\n<script>\n    export default {\n    // 1. ADICIONADO: Estado inicial para o Vue monitorar as atualizações da turbidez\n    data() {\n        return {\n            turbidez: 0 // Valor inicial padrão\n        }\n    },\n\n    computed: {\n\n        // STATUS BASEADO EM NTU REAL\n        statusText() {\n            /*\n                REFERÊNCIA REAL (NTU)\n                0 - 5     → Excelente\n                6 - 20    → Boa\n                21 - 50   → Atenção\n                51+       → Crítica\n            */\n            if (this.turbidez <= 5) {\n                return \"EXCELENTE\"\n            }\n            if (this.turbidez <= 20) {\n                return \"BOA\"\n            }\n            if (this.turbidez <= 50) {\n                return \"ATENÇÃO\"\n            }\n            return \"CRÍTICA\"\n        },\n\n        // COR DO STATUS\n        statusColor() {\n            if (this.turbidez <= 5) {\n                return \"#22C55E\"\n            }\n            if (this.turbidez <= 20) {\n                return \"#3BA4FF\"\n            }\n            if (this.turbidez <= 50) {\n                return \"#F59E0B\"\n            }\n            return \"#EF4444\"\n        },\n\n        // TEXTO AUTOMÁTICO\n        insightText() {\n            if (this.turbidez <= 5) {\n                return \"Água visualmente limpa e adequada.\"\n            }\n            if (this.turbidez <= 20) {\n                return \"Pequena presença de partículas suspensas.\"\n            }\n            if (this.turbidez <= 50) {\n                return \"Aumento perceptível da turbidez. Recomenda-se monitoramento.\"\n            }\n            return \"Alta concentração de resíduos detectada. Limpeza recomendada.\"\n        },\n\n        // COR DO GAUGE\n        gaugeColor() {\n            if (this.turbidez <= 5) {\n                return \"#22C55E\"\n            }\n            if (this.turbidez <= 20) {\n                return \"#3BA4FF\"\n            }\n            if (this.turbidez <= 50) {\n                return \"#F59E0B\"\n            }\n            return \"#EF4444\"\n        },\n\n        // ESTILO DO GAUGE\n        gaugeStyle() {\n            /*\n                ESCALA VISUAL:\n                0 → 100 NTU\n            */\n            const maxNTU = 100\n            const percent = Math.min(this.turbidez, maxNTU) / maxNTU\n            const dash = 251 * percent\n\n            return {\n                stroke: this.gaugeColor,\n                strokeDasharray: `${dash} 251`\n            }\n        }\n    },\n\n    watch: {\n        // RECEBE DADOS MQTT / NODE-RED\n        msg: {\n            handler(newMsg) {\n                if (newMsg && newMsg.payload !== undefined && newMsg.payload !== null) {\n                    // Garante que o valor recebido seja convertido em número puro\n                    this.turbidez = Number(newMsg.payload);\n                }\n            },\n            immediate: true, // Captura o valor imediatamente se ele já estiver no fluxo\n            deep: true\n        }\n    }\n}\n</script>\n\n<style>\n    /* CARD */\n    .card {\n        background: #0B1728;\n        border-radius: 18px;\n        padding: 16px;\n        color: #F5F7FA;\n        box-shadow: 0 0 20px rgba(0, 0, 0, 0.3);\n        width: 100%;\n        height: 100%;\n        box-sizing: border-box;\n        display: flex;\n        flex-direction: column;\n        justify-content: space-between;\n    }\n\n    /* TITULO */\n    .title {\n        font-size: clamp(16px, 1.8vw, 22px);\n        font-weight: bold;\n        color: #3BA4FF;\n        text-align: center;\n        margin-bottom: 8px;\n    }\n\n    /* CONTAINER */\n    .gauge-container {\n        position: relative;\n        width: 100%;\n        height: 230px;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n    }\n\n    /* SVG */\n    .gauge {\n        width: 100%;\n        height: 100%;\n    }\n\n    /* FUNDO */\n    .gauge-bg {\n        fill: none;\n        stroke: #1B2A41;\n        stroke-width: 18;\n        stroke-linecap: round;\n    }\n\n    /* PREENCHIMENTO */\n    .gauge-fill {\n        fill: none;\n        stroke-width: 18;\n        stroke-linecap: round;\n        transition: 0.5s ease;\n    }\n\n    /* VALOR CENTRAL */\n    .value-container {\n        position: absolute;\n        top: 58%;\n        left: 50%;\n        transform: translate(-50%, -50%);\n        text-align: center;\n    }\n\n    /* NUMERO */\n    .value {\n        font-size: clamp(34px, 4vw, 54px);\n        font-weight: bold;\n        line-height: 1;\n    }\n\n    /* NTU */\n    .unit {\n        font-size: clamp(14px, 1.5vw, 20px);\n        color: #A9B4C2;\n        margin-top: 4px;\n    }\n\n    /* STATUS */\n    .status {\n        margin-top: 6px;\n        font-size: clamp(14px, 1.5vw, 18px);\n        text-align: center;\n        font-weight: bold;\n    }\n\n    /* INSIGHT */\n    .insight {\n        margin-top: 10px;\n        text-align: center;\n        font-size: clamp(11px, 1.2vw, 15px);\n        color: #A9B4C2;\n        line-height: 1.4;\n    }\n\n    /* MOBILE */\n    @media (max-width: 600px) {\n        .card {\n            padding: 12px;\n        }\n\n        .gauge-container {\n            height: 180px;\n        }\n    }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1160,
        "y": 360,
        "wires": [
            []
        ]
    },
    {
        "id": "864e0f5927906959",
        "type": "ui-template",
        "z": "ce1e45cbf51fc423",
        "group": "06d9654aeca5098a",
        "page": "",
        "ui": "",
        "name": "NIvel De Agua",
        "order": 1,
        "width": "0",
        "height": "0",
        "head": "",
        "format": "<template>\n    <div class=\"card\">\n\n        <div class=\"title\">\n            NÍVEL DA ÁGUA\n        </div>\n\n        <div class=\"gauge-container\">\n\n            <div class=\"native-tank-outline\">\n\n                <div class=\"native-tank-fill\" :style=\"tankStyle\">\n\n                    <svg class=\"wave-svg\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\"\n                        preserveAspectRatio=\"none\">\n                        <path\n                            d=\"M0,60 C150,100 350,20 500,60 C650,100 850,20 1000,60 C1150,100 1350,20 1500,60 L1500,120 L0,120 Z\"\n                            class=\"wave-path\"></path>\n                    </svg>\n\n                </div>\n\n                <div class=\"value-container\">\n                    <span class=\"value\">{{ nivel }}</span>\n                    <span class=\"unit\">%</span>\n                </div>\n\n            </div>\n\n        </div>\n\n        <div class=\"status\">\n            Status:\n            <span :style=\"{ color: statusColor }\">\n                {{ statusText }}\n            </span>\n        </div>\n\n        <div class=\"insight\">\n            {{ insightText }}\n        </div>\n\n    </div>\n</template>\n\n<script>\n    export default {\n    data() {\n        return {\n            nivel: 0\n        }\n    },\n    computed: {\n        statusText() {\n            if (this.nivel <= 20) return \"CRÍTICO\"\n            if (this.nivel <= 40) return \"BAIXO\"\n            if (this.nivel <= 70) return \"NORMAL\"\n            return \"IDEAL\"\n        },\n        statusColor() {\n            if (this.nivel <= 20) return \"#EF4444\"\n            if (this.nivel <= 40) return \"#F59E0B\"\n            if (this.nivel <= 70) return \"#3BA4FF\"\n            return \"#22C55E\"\n        },\n        insightText() {\n            if (this.nivel <= 20) return \"Volume crítico. Risco de desabastecimento.\"\n            if (this.nivel <= 40) return \"Volume abaixo da média. Economize água.\"\n            if (this.nivel <= 70) return \"Volume seguro e estável para consumo.\"\n            return \"Reservatório operando em excelente capacidade.\"\n        },\n        tankStyle() {\n            return {\n                height: `${this.nivel}%`,\n                backgroundColor: '#3da8ff' \n            }\n        }\n    },\n    watch: {\n        msg() {\n            if (this.msg?.payload != null) {\n                this.nivel = Math.min(Math.max(Number(this.msg.payload), 0), 100)\n            }\n        }\n    }\n}\n</script>\n\n<style>\n    /* CARD - 100% IDÊNTICO AO DE TURBIDEZ */\n    .card {\n        background: #0B1728;\n        border-radius: 18px;\n        padding: 16px;\n        color: #F5F7FA;\n        box-shadow: 0 0 20px rgba(0, 0, 0, 0.3);\n        width: 100%;\n        height: 100%;\n        box-sizing: border-box;\n        display: flex;\n        flex-direction: column;\n        justify-content: space-between;\n    }\n\n    /* TÍTULO - 100% IDÊNTICO AO DE TURBIDEZ */\n    .title {\n        font-size: clamp(16px, 1.8vw, 22px);\n        font-weight: bold;\n        color: #3BA4FF;\n        text-align: center;\n        margin-bottom: 8px;\n    }\n\n    /* CONTAINER DO GAUGE - TRAVADO NOS MESMOS 230PX DA TURBIDEZ */\n    .gauge-container {\n    position: relative;\n    width: 100%;\n    height: 185px;\n    flex-shrink: 0; /* IMPEDE o tanque de encolher se o texto crescer */\n    flex-grow: 0; /* IMPEDE o tanque de esticar se o texto sumir */\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    margin: 4px 0;\n    padding: 0 4px;\n    box-sizing: border-box;\n    }\n\n    /* O TANQUE HORIZONTAL FLUIDO */\n    .native-tank-outline {\n        width: 100%;\n        height: 100%;\n        border: 3.5px solid #3da8ff;\n        border-radius: 14px;\n        position: relative;\n        overflow: hidden;\n        background: #09121f;\n        display: flex;\n        align-items: flex-end;\n        box-shadow: inset 0 0 15px rgba(61, 168, 255, 0.15);\n        box-sizing: border-box;\n    }\n\n    /* O LÍQUIDO */\n    .native-tank-fill {\n        width: 100%;\n        position: relative;\n        transition: height 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    /* A ONDA ANIMADA */\n    .wave-svg {\n        position: absolute;\n        top: -22px;\n        left: 0;\n        width: 200%;\n        height: 25px;\n    }\n\n    .wave-path {\n        fill: #3da8ff;\n        animation: move-wave 5s linear infinite;\n    }\n\n    @keyframes move-wave {\n        0% {\n            transform: translateX(0);\n        }\n\n        50% {\n            transform: translateX(-25%);\n        }\n\n        100% {\n            transform: translateX(0);\n        }\n    }\n\n    /* VALOR CENTRAL - MESMA ESCALA VISUAL DA TURBIDEZ */\n    .value-container {\n        position: absolute;\n        top: 50%;\n        left: 50%;\n        transform: translate(-50%, -50%);\n        text-align: center;\n        z-index: 10;\n        color: #ffffff;\n        pointer-events: none;\n        display: flex;\n        align-items: baseline;\n        justify-content: center;\n    }\n\n    /* NÚMERO - MESMO TAMANHO DA TURBIDEZ */\n    .value {\n        font-size: clamp(34px, 4vw, 54px);\n        font-weight: bold;\n        line-height: 1;\n        font-family: sans-serif;\n        text-shadow: 0 2px 6px rgba(0, 0, 0, 0.7);\n    }\n\n    /* UNIDADE % - MESMO TAMANHO DO NTU */\n    .unit {\n        font-size: clamp(14px, 1.5vw, 20px);\n        color: #A9B4C2;\n        margin-left: 4px;\n        font-weight: bold;\n        text-shadow: 0 2px 6px rgba(0, 0, 0, 0.7);\n    }\n\n    /* STATUS - 100% IDÊNTICO AO DE TURBIDEZ */\n    .status {\n        margin-top: 6px;\n        font-size: clamp(14px, 1.5vw, 18px);\n        text-align: center;\n        font-weight: bold;\n    }\n\n    /* INSIGHT - 100% IDÊNTICO AO DE TURBIDEZ */\n    .insight {\n    text-align: center;\n    font-size: clamp(10px, 1.1vw, 13px);\n    color: #A9B4C2;\n    line-height: 1.4;\n    margin-top: 2px;\n    \n    /* TRAVAS DE TAMANHO */\n    height: 36px; /* Força uma altura fixa equivalente a até 2 linhas */\n    display: flex;\n    align-items: center; /* Centraliza o texto verticalmente dentro desse bloco fixo */\n    justify-content: center;\n    overflow: hidden; /* Garante que o texto não quebre o layout se for gigante */\n    }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 560,
        "y": 360,
        "wires": [
            []
        ]
    },
    {
        "id": "503887ab20c993a4",
